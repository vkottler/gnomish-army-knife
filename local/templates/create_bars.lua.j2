	local id = spec_info[1]
	local name = spec_info[2]
	local spec_bind_count = 0
{% for id, data in bars["specializations"].items()|sort(attribute='0') %}
{% if id|int != 0 %}

	if id == {{id}} then
{% for bind in data.get("array", []) %}
{% if bind[1] %}
		{{pickup_action(bind[1])}}
		if GetCursorInfo() then
			-- {{bind[0]}}
			{{place_action(bind[0], 3)}}
			spec_bind_count = spec_bind_count + 1
		else
			print("(spec) Couldn't bind slot {{bind[0]}}:", [[
{{bind[1]}}]])
		end
{% endif %}
{% endfor %}
{% for key, bind in data.get("by_key", {}).items()|sort(attribute='0') %}
{% if bind %}
		{{pickup_action(bind)}}
		if GetCursorInfo() then
			-- {{key}}
			{{place_action(key, 3)}}
			spec_bind_count = spec_bind_count + 1
		else
			print("(spec) Couldn't bind slot {{key}}:", [[
{{bind}}]])
		end
{% endif %}
{% endfor %}
	end
{% endif %}
{% endfor %}

	print("Placed " .. spec_bind_count .. " " .. name .. " (" .. id .. ") actions.")

	id = C_ClassTalents.GetActiveHeroTalentSpec()
	if not id then
		return
	end
	spec_bind_count = 0
{% for id, data in bars["specializations"]["hero"].items()|sort(attribute='0') %}
{% if id|int != 0 %}

	if id == {{id}} then
{% for key, bind in data.get("by_key", {}).items()|sort(attribute='0') %}
{% if bind %}
		{{pickup_action(bind)}}
		if GetCursorInfo() then
			-- {{key}}
			{{place_action(key, 3)}}
			spec_bind_count = spec_bind_count + 1
		else
			print("(spec) Couldn't bind slot {{key}}:", [[
{{bind}}]])
		end
{% endif %}
{% endfor %}
	end
{% endif %}
{% endfor %}

	print("Placed " .. spec_bind_count .. " " .. id .. " (hero) actions.")
end

function GakSetRoleActions()
	local spec_info = {GetSpecializationInfo(GetSpecialization())}
	local role = spec_info[5]
	local role_bind_count = 0
{% for role, role_data in bars["roles"].items() %}

	if role == "{{role}}" then
{% for key, bind in role_data.get("by_key", {}).items()|sort(attribute='0') %}
		{{pickup_action(bind)}}
		if GetCursorInfo() then
			-- {{key}}
			{{place_action(key, 3)}}
			role_bind_count = role_bind_count + 1
		else
			print("(role) Couldn't bind slot {{key}}:", [[
{{bind[1]}}]])
		end
{% endfor %}
	end
{% endfor %}

	print("Placed " .. role_bind_count .. " " .. role .. " actions.")
end

function GakSetActionBars()
	-- Clear all existing bars.
	GakClearActionBars()

	-- Set character-specific macros (due to specialization-specific macro
	-- indices).
	GakSetCharacterMacros()

	-- Make sure cursor is clear.
	ClearCursor()

	-- Set all binds.
	GakSetGlobalActions()
	GakSetRoleActions()
	GakSetClassActions()
	GakSetSpecializationActions()
end
